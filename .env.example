# ---------------------------------------------------------------------------
# Docker MCP Server — example environment configuration
# Copy to `.env` (loaded automatically) or export these in your MCP client.
# Crafted by SoyRage Agency — https://soyrage.es/
# ---------------------------------------------------------------------------

# How to reach the Docker Engine.
# Leave empty to use the platform default:
#   - Linux/macOS : unix:///var/run/docker.sock
#   - Windows     : npipe:////./pipe/docker_engine
# Or point to a remote/TCP daemon, e.g. tcp://192.168.1.10:2375
DOCKER_HOST=

# ----- TLS (only needed for secured remote TCP daemons) --------------------
# Absolute path to a directory containing ca.pem, cert.pem and key.pem.
DOCKER_CERT_PATH=
# Set to "1" to verify the daemon certificate (recommended for remote hosts).
DOCKER_TLS_VERIFY=

# ----- Safety controls -----------------------------------------------------
# When "true", every state-changing tool (start/stop/restart/remove/deploy…)
# is disabled and the server exposes read-only insight only. Great for demos.
DOCKER_MCP_READONLY=false

# When "true", the `exec_in_container` tool is registered. It is OFF by default
# because running arbitrary commands inside containers is powerful.
DOCKER_MCP_ALLOW_EXEC=false

# Optional comma-separated allowlist of container names (or name prefixes).
# When set, the server will only operate on matching containers. Empty = all.
# Example: DOCKER_MCP_CONTAINER_ALLOWLIST=web,api,db
DOCKER_MCP_CONTAINER_ALLOWLIST=

# Default number of log lines returned by `container_logs` when not specified.
DOCKER_MCP_DEFAULT_LOG_TAIL=200

# Working directory used to resolve relative Compose project paths.
# Defaults to the process working directory.
DOCKER_MCP_COMPOSE_CWD=

# Log verbosity for the server's own diagnostics (written to stderr):
# one of: debug | info | warn | error
DOCKER_MCP_LOG_LEVEL=info

# ----- Modular plugins -----------------------------------------------------
# The server is built from toggleable capability plugins. Names:
#   about (locked), containers, logs, images, system, compose, lifecycle
# Enable ONLY these (comma-separated). Empty = load all.
DOCKER_MCP_PLUGINS=
# Disable these regardless (comma-separated). 'about' cannot be disabled.
DOCKER_MCP_DISABLED_PLUGINS=

# ----- Interactive panel ---------------------------------------------------
# Bind address and port for the web dashboard (docker-mcp-panel).
DOCKER_MCP_PANEL_HOST=127.0.0.1
DOCKER_MCP_PANEL_PORT=4600
# Serve realistic demo data instead of touching a real daemon (great for
# previews, screenshots and client demos).
DOCKER_MCP_PANEL_DEMO=false
# Expose the Prometheus /metrics endpoint (scrape from Prometheus, Zabbix, …).
DOCKER_MCP_PANEL_METRICS=true

# Optional path to a JSON config file (defaults to ./docker-mcp.config.json).
# DOCKER_MCP_CONFIG=./docker-mcp.config.json
